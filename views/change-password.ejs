<%- include('partials/head', { title: 'Change Password | Cloak it' }) %>
<%- include('partials/navbar', { navType: 'app', activePage: 'change-password' }) %>

<main class="auth-layout">
    <section class="glass-panel auth-panel">
        <span class="hero-kicker">Account security</span>
        <h1 class="auth-title">Change your password.</h1>
        <p class="auth-copy">
            Update your password to keep your anonymous inbox protected.
        </p>

        <%- include('partials/flash-alerts') %>

        <form action="/change-password" method="POST" class="auth-form">
            <div class="mb-3">
                <label for="currentPassword" class="form-label">Current password</label>
                <input type="password" class="form-control custom-input" name="currentPassword" id="currentPassword" placeholder="Current password" required>
            </div>

            <div class="mb-3">
                <label for="newPassword" class="form-label">New password</label>
                <input type="password" class="form-control custom-input" name="newPassword" id="newPassword" placeholder="New password" required>
            </div>

            <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm new password</label>
                <input type="password" class="form-control custom-input" name="confirmPassword" id="confirmPassword" placeholder="Confirm new password" required>
            </div>

            <p id="error" class="client-error"></p>

            <button type="submit" class="btn form-btn"><i class="bi bi-shield-check btn-icon" aria-hidden="true"></i><span>Update Password</span></button>
        </form>
    </section>
</main>

<%- include('partials/legal-footer') %>
</div>

<%- include('partials/legal-modals') %>
<%- include('partials/scripts', { pageScripts: ['/js/change-password.js'] }) %>
