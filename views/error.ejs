<%- include('partials/head', { title: `${status || 500} | Cloak it` }) %>
<%- include('partials/navbar', { navType: user ? 'app' : 'auth', activePage: '' }) %>

<main class="auth-layout">
    <section class="glass-panel auth-panel">
        <span class="hero-kicker">Something happened</span>
        <h1 class="auth-title"><%= status || 500 %></h1>
        <p class="auth-copy">
            <%= message || 'Something went wrong. Please try again.' %>
        </p>

        <div class="d-flex flex-column flex-sm-row gap-3">
            <a href="/" class="btn hero-btn"><i class="bi bi-house btn-icon" aria-hidden="true"></i><span>Go Home</span></a>
            <% if (user) { %>
                <a href="/dashboard" class="btn hero-secondary"><i class="bi bi-envelope btn-icon" aria-hidden="true"></i><span>Back to Dashboard</span></a>
            <% } else { %>
                <a href="/login" class="btn hero-secondary"><i class="bi bi-box-arrow-in-right btn-icon" aria-hidden="true"></i><span>Login</span></a>
            <% } %>
        </div>
    </section>
</main>

<%- include('partials/legal-footer') %>
</div>

<%- include('partials/legal-modals') %>
<%- include('partials/scripts', { pageScripts: [] }) %>
